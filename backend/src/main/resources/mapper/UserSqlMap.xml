<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.yjb.reactchat.mapper.UserMapper">
    <insert id="insert" parameterType="map">
        INSERT INTO tb_user (id, name, created_at, updated_at)
        VALUES (#{id}, #{name}, NOW(), NOW());
    </insert>

    <select id="selectAll" parameterType="map" resultType="com.yjb.reactchat.dto.UserDto">
        SELECT id, name, created_at
        FROM tb_user
    </select>

    <delete id="delete" parameterType="map">
        DELETE FROM tb_user
        WHERE id = #{id}
    </delete>
</mapper>
